      { "name": "search-first", "whenSteps": ["architect"], "priority": 40, "tags": ["official"] },
      { "name": "iterative-retrieval", "whenSteps": ["architect"], "priority": 40, "tags": ["official"] }
    ],
    "issue-manager": [
      { "name": "issue-structured-spec", "whenSteps": ["issue"], "priority": 50, "tags": ["official"] },
      { "name": "search-first", "whenSteps": ["issue"], "priority": 40, "tags": ["official"] },
      { "name": "iterative-retrieval", "whenSteps": ["issue"], "priority": 40, "tags": ["official"] }
    ],
    "developer": [
      { "name": "project-meta-web-copilot", "whenSteps": ["implement"], "priority": 60, "tags": ["official", "core"] },
      { "name": "developer-frontend-web", "whenSteps": ["implement"], "priority": 50, "tags": ["official"] },
      { "name": "developer-backend-web", "whenSteps": ["implement"], "priority": 50, "tags": ["official"] },
      { "name": "developer-fullstack-web", "whenSteps": ["implement"], "priority": 50, "tags": ["official"] }
