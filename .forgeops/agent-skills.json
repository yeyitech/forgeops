      { "name": "tester-web-quality-gate", "whenSteps": ["test"], "priority": 50, "tags": ["official"] },
      { "name": "verification-loop", "whenSteps": ["test"], "priority": 40, "tags": ["official"] }
    ],
    "reviewer": [
      { "name": "project-meta-web-copilot", "whenSteps": ["review"], "priority": 60, "tags": ["official", "core"] },
      { "name": "reviewer-web-merge-governance", "whenSteps": ["review"], "priority": 50, "tags": ["official"] },
      { "name": "security-review", "whenSteps": ["review"], "priority": 45, "tags": ["official"] },
      { "name": "verification-loop", "whenSteps": ["review"], "priority": 40, "tags": ["official"] }
